# Number Guessing Game — configuration
# Copy to .env and fill in APP_PUBKEY and APP_SECRET_KEY.

# On-chain game wallet. Incoming guesses are sent here; payouts are sent from here.
# Generate a keypair with: node scripts/generate-keypair.js (from usernode-dapp-starter)
APP_PUBKEY=

# Secret key paired with APP_PUBKEY. Used server-side to sign payout transactions.
APP_SECRET_KEY=

# Sidecar node RPC (Docker-internal network name in production).
NODE_RPC_URL=http://usernode-node:3000

# Round duration in milliseconds (default 24 hours).
TIMER_DURATION_MS=86400000

# Minimum players before a round can end (default 2).
# Set to 1 if you want rounds to resolve with a single guesser.
MIN_PLAYERS=2

# This app uses NO database — all state lives on-chain (DATABASE_URL is unused).
#
# Platform-injected at runtime — do not set manually:
# JWT_SECRET=
# PORT=3000
# USERNODE_ENV=
