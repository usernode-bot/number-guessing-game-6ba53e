{
  "name": "Number Guessing Game",
  "secrets": [
    {
      "key": "APP_SECRET_KEY",
      "description": "Secret key for the game wallet (paired with the hardcoded APP_PUBKEY), used to sign server-side round-lifecycle and payout transactions on the real testnet. Required in production; staging resolves to an empty key and skips real payouts.",
      "required": true,
      "private": true,
      "staging_default": ""
    },
    {
      "key": "TIMER_DURATION_MS",
      "description": "Normal round duration in milliseconds before the timer expires.",
      "required": false,
      "default": "86400000"
    },
    {
      "key": "ROUND_TIMED_MS",
      "description": "Timed Mode round duration in milliseconds (used when timedMode is active).",
      "required": false,
      "default": "60000"
    },
    {
      "key": "MIN_PLAYERS",
      "description": "Minimum number of guesses required before a normal round can end. If not met, the round extends.",
      "required": false,
      "default": "2"
    }
  ],
  "tests": [
    {
      "name": "Game loads without console errors",
      "path": "/",
      "expectSelector": ".header"
    },
    {
      "name": "Leaderboard tab renders",
      "path": "/",
      "expectSelector": ".bottom-nav"
    },
    {
      "name": "Game state endpoint returns data",
      "path": "/__numguess/state",
      "expectText": "appPubkey"
    },
    {
      "name": "Duration badge renders on active round",
      "path": "/__numguess/state",
      "expectText": "activeDurationMs"
    },
    {
      "name": "Track selector renders",
      "path": "/",
      "expectSelector": ".track-selector"
    },
    {
      "name": "State endpoint returns per-track data",
      "path": "/__numguess/state",
      "expectText": "\"1h\""
    },
    {
      "name": "State endpoint includes all four tracks",
      "path": "/__numguess/state",
      "expectText": "\"1w\""
    },
    {
      "name": "State endpoint includes bestWinGuessCount in player stats",
      "path": "/__numguess/state",
      "expectText": "bestWinGuessCount"
    },
    {
      "name": "State endpoint includes difficulties map",
      "path": "/__numguess/state",
      "expectText": "\"difficulties\""
    },
    {
      "name": "State endpoint includes difficulty field on rounds",
      "path": "/__numguess/state",
      "expectText": "\"difficulty\""
    },
    {
      "name": "State endpoint includes easy difficulty bucket",
      "path": "/__numguess/state",
      "expectText": "\"easy\""
    },
    {
      "name": "State endpoint includes hard difficulty bucket",
      "path": "/__numguess/state",
      "expectText": "\"hard\""
    },
    {
      "name": "Leaderboard difficulty selector renders",
      "path": "/",
      "expectSelector": "#lb-medium"
    },
    {
      "name": "Mock probe reports disabled (no mock layer)",
      "path": "/__mock/enabled",
      "expectText": "{\"enabled\":false}"
    },
    {
      "name": "Usernames cache serves seeded staging name",
      "path": "/__usernames/state",
      "expectText": "alice_s"
    },
    {
      "name": "Sign-in gate markup is present",
      "path": "/",
      "expectSelector": "#signin-gate"
    },
    {
      "name": "Welcome greeting element is present",
      "path": "/",
      "expectSelector": "#welcome-greeting"
    }
  ]
}
