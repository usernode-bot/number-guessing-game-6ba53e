{
  "name": "Number Guessing Game",
  "secrets": [
    {
      "key": "APP_PUBKEY",
      "description": "On-chain game wallet address. Incoming guesses are sent here; payouts are sent from here.",
      "required": true,
      "private": false,
      "default": "utpk1rn7sakz2nvk2uzlvf4spzl22374z9u0jvah8yqs0djc722u96uqs20yx79",
      "staging_default": "utpk1rn7sakz2nvk2uzlvf4spzl22374z9u0jvah8yqs0djc722u96uqs20yx79"
    },
    {
      "key": "APP_SECRET_KEY",
      "description": "Secret key paired with APP_PUBKEY, used to sign server-side payout transactions.",
      "required": false,
      "private": true,
      "staging_default": ""
    },
    {
      "key": "NODE_RPC_URL",
      "description": "Sidecar Usernode RPC endpoint. Resolves via Docker network in production.",
      "required": false,
      "default": "http://usernode-node:3000"
    },
    {
      "key": "TIMER_DURATION_MS",
      "description": "Round duration in milliseconds before the timer expires.",
      "required": false,
      "default": "86400000"
    },
    {
      "key": "MIN_PLAYERS",
      "description": "Minimum number of guesses required before a round can end. If not met, the round extends.",
      "required": false,
      "default": "2"
    }
  ],
  "tests": [
    {
      "name": "Game loads without console errors",
      "path": "/",
      "expectSelector": ".header"
    },
    {
      "name": "Leaderboard tab renders",
      "path": "/",
      "expectSelector": ".bottom-nav"
    }
  ]
}
